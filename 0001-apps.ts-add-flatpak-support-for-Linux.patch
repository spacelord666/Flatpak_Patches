-export function checkAppExists(appName: string) {
+export async function checkAppExists(appName: string) {
   if (process.platform === "win32") return true
-  if (process.platform === "linux") return true
+  if (process.platform === "linux") return checkLinuxApp(appName)
   return checkMacosApp(appName)
 }

-export function resolveAppPath(appName: string) {
-  if (process.platform !== "win32") return appName
-  return resolveWindowsAppPath(appName)
+export async function resolveAppPath(appName: string) {
+  if (process.platform === "win32") return resolveWindowsAppPath(appName)
+  if (process.platform === "linux") return resolveLinuxAppPath(appName)
+  return appName
+}
+
+async function checkLinuxApp(appName: string): Promise<boolean> {
+  // Check if the binary exists on PATH
+  try {
+    await execFilePromise("which", [appName])
+    return true
+  } catch {
+    // not on PATH — try flatpak
+  }
+
+  const flatpakId = FLATPAK_APP_MAP[appName]
+  if (!flatpakId) return false
+
+  try {
+    await execFilePromise("flatpak", ["info", flatpakId])
+    return true
+  } catch {
+    return false
+  }
+}
+
+async function resolveLinuxAppPath(appName: string): Promise<string | null> {
+  // Check PATH first
+  try {
+    const { stdout } = await execFilePromise("which", [appName])
+    const path = stdout.trim()
+    if (path) return path
+  } catch {
+    // not on PATH
+  }
+
+  // Check flatpak
+  const flatpakId = FLATPAK_APP_MAP[appName]
+  if (!flatpakId) return null
+
+  try {
+    await execFilePromise("flatpak", ["info", flatpakId])
+    return `flatpak run ${flatpakId}`
+  } catch {
+    return null
+  }
 }

